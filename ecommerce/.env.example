# ============================================================
# Do'kon — Environment Variables
# ============================================================
# Nusxa oling: cp .env.example .env.local
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Railway yoki Supabase PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────
# Tasodifiy kalit: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (ixtiyoriy) ──────────────────────────────────
# https://console.cloud.google.com dan oling
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Cloudinary (rasm yuklash) ─────────────────────────────────
# https://cloudinary.com dan oling
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Click To'lov tizimi ───────────────────────────────────────
# https://my.click.uz dan oling
NEXT_PUBLIC_CLICK_MERCHANT_ID=""
NEXT_PUBLIC_CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""

# ── Payme To'lov tizimi ───────────────────────────────────────
# https://merchant.payme.uz dan oling
NEXT_PUBLIC_PAYME_MERCHANT_ID=""
PAYME_SECRET_KEY=""
# Test rejimi uchun: true | Production uchun: false
PAYME_TEST_MODE="true"

# ── Email (ixtiyoriy, parol tiklash uchun) ────────────────────
# Resend.com yoki Gmail SMTP
RESEND_API_KEY=""
EMAIL_FROM="noreply@dokon.uz"

# ── App settings ─────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Do'kon"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Sentry (production monitoring, ixtiyoriy) ────────────────
SENTRY_DSN=""
